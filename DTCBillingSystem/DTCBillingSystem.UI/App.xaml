<Application x:Class="DTCBillingSystem.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DTCBillingSystem.UI"
             xmlns:conv="clr-namespace:DTCBillingSystem.UI.Converters"
             xmlns:enums="clr-namespace:DTCBillingSystem.Core.Models.Enums;assembly=DTCBillingSystem.Core"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Converters -->
        <conv:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <conv:BoolToActionTextConverter x:Key="BoolToActionTextConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Customer Types -->
        <ObjectDataProvider x:Key="CustomerTypes" 
                          MethodName="GetValues" 
                          ObjectType="{x:Type enums:CustomerType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:CustomerType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- Sort Options -->
        <x:Array x:Key="SortOptions" Type="sys:String" 
                xmlns:sys="clr-namespace:System;assembly=mscorlib">
            <sys:String>Name</sys:String>
            <sys:String>AccountNumber</sys:String>
            <sys:String>Type</sys:String>
            <sys:String>Zone</sys:String>
            <sys:String>Balance</sys:String>
            <sys:String>LastBillingDate</sys:String>
        </x:Array>

        <!-- Styles -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="35"/>
        </Style>
    </Application.Resources>
</Application>
