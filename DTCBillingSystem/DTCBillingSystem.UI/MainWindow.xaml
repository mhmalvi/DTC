<Window x:Class="DTCBillingSystem.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:DTCBillingSystem.UI"
        mc:Ignorable="d"
        Title="DTC Billing System" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Panel -->
        <materialDesign:Card Grid.Column="0" Background="{DynamicResource PrimaryHueDarkBrush}" Padding="8">
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="16">
                    <TextBlock Text="DTC Billing System" 
                             Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                             Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    <TextBlock Text="{Binding CurrentUserName}" 
                             Style="{StaticResource MaterialDesignCaptionTextBlock}"
                             Foreground="{DynamicResource PrimaryHueLightBrush}"
                             Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Dashboard"
                            HorizontalContentAlignment="Left"
                            Margin="8,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Margin="0,0,8,0"/>
                            <TextBlock Text="Dashboard"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Customers"
                            HorizontalContentAlignment="Left"
                            Margin="8,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountMultiple" Margin="0,0,8,0"/>
                            <TextBlock Text="Customers"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="BillGeneration"
                            HorizontalContentAlignment="Left"
                            Margin="8,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocument" Margin="0,0,8,0"/>
                            <TextBlock Text="Generate Bills"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding LogoutCommand}"
                            HorizontalContentAlignment="Left"
                            Margin="8,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Margin="0,0,8,0"/>
                            <TextBlock Text="Logout"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </materialDesign:Card>

        <!-- Main Content Area -->
        <Frame x:Name="MainFrame" 
               Grid.Column="1" 
               NavigationUIVisibility="Hidden"
               Margin="16"/>
    </Grid>
</Window>
