<Page x:Class="DTCBillingSystem.UI.Views.BillGenerationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:DTCBillingSystem.UI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Generate Bills">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Generate Bills" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,8"/>
            <TextBlock Text="Generate monthly bills for customers" Style="{StaticResource MaterialDesignBody1TextBlock}" Opacity="0.6"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Customer List -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,16,0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search and Filter -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBox Width="200" 
                                 materialDesign:HintAssist.Hint="Search customers"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        
                        <ComboBox Width="150" Margin="16,0,0,0"
                                  materialDesign:HintAssist.Hint="Customer Type"
                                  ItemsSource="{Binding CustomerTypes}"
                                  SelectedItem="{Binding SelectedCustomerType}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>

                    <!-- Customer DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected}"
                                                   Header="Select"
                                                   Width="Auto"/>
                            <DataGridTextColumn Binding="{Binding ShopNo}"
                                               Header="Shop No."
                                               Width="Auto"/>
                            <DataGridTextColumn Binding="{Binding Name}"
                                               Header="Name"
                                               Width="*"/>
                            <DataGridTextColumn Binding="{Binding Floor}"
                                               Header="Floor"
                                               Width="Auto"/>
                            <DataGridTextColumn Binding="{Binding CustomerType}"
                                               Header="Type"
                                               Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <!-- Bill Generation Options -->
            <materialDesign:Card Grid.Column="1" Width="300">
                <StackPanel Margin="16">
                    <TextBlock Text="Bill Generation Options" 
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,16"/>

                    <DatePicker materialDesign:HintAssist.Hint="Billing Month"
                                SelectedDate="{Binding BillingMonth}"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                Margin="0,0,0,16"/>

                    <TextBox materialDesign:HintAssist.Hint="Notes"
                             Text="{Binding Notes}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Height="100"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,16"/>

                    <Button Content="Generate Bills"
                            Command="{Binding GenerateBillsCommand}"
                            Style="{StaticResource MaterialDesignPrimaryButton}"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Progress and Status -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <ProgressBar Value="{Binding Progress}"
                         Maximum="100"
                         Height="4"
                         Margin="0,0,0,8"
                         Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                       Foreground="{Binding HasError, Converter={StaticResource BooleanToErrorBrushConverter}}"
                       TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page> 