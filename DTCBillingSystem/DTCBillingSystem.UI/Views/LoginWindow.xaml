<Window x:Class="DTCBillingSystem.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:DTCBillingSystem.UI.Converters"
        mc:Ignorable="d"
        Title="DTC Billing System - Login" 
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <materialDesign:Card UniformCornerRadius="15" 
                        Background="{DynamicResource MaterialDesignPaper}"
                        materialDesign:ElevationAssist.Elevation="Dp4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource PrimaryHueDarkBrush}"
                    CornerRadius="15,15,0,0">
                <StackPanel Margin="20">
                    <materialDesign:PackIcon Kind="AccountCircle" 
                                           Width="80" Height="80" 
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource MaterialDesignPaper}"/>
                    <TextBlock Text="LOGIN" 
                             HorizontalAlignment="Center"
                             FontSize="28" 
                             FontWeight="Bold"
                             Margin="0,10,0,0"
                             Foreground="{DynamicResource MaterialDesignPaper}"/>
                </StackPanel>
            </Border>

            <!-- Login Form -->
            <StackPanel Grid.Row="1" 
                      Margin="30,20">
                <!-- Username -->
                <TextBox x:Name="usernameTextBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignFilledTextBox}"
                         materialDesign:HintAssist.Hint="Username"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Margin="0,10"/>

                <!-- Password -->
                <Grid Margin="0,10">
                    <PasswordBox x:Name="passwordBox"
                               Style="{StaticResource MaterialDesignFilledPasswordBox}"
                               materialDesign:HintAssist.Hint="Password"
                               materialDesign:TextFieldAssist.HasClearButton="True"
                               PasswordChanged="PasswordBox_PasswordChanged"
                               Margin="0,0,40,0"/>
                    
                    <TextBox x:Name="textBox"
                            Style="{StaticResource MaterialDesignFilledTextBox}"
                            materialDesign:HintAssist.Hint="Password"
                            materialDesign:TextFieldAssist.HasClearButton="True"
                            TextChanged="TextBox_TextChanged"
                            Visibility="Collapsed"
                            Margin="0,0,40,0"/>
                    
                    <ToggleButton x:Name="ShowPasswordButton"
                                Style="{StaticResource MaterialDesignActionToggleButton}"
                                Height="24" Width="24"
                                ToolTip="Show/Hide Password"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Checked="ShowPasswordButton_Checked"
                                Unchecked="ShowPasswordButton_Unchecked">
                        <ToggleButton.Content>
                            <materialDesign:PackIcon Kind="EyeOutline"/>
                        </ToggleButton.Content>
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="EyeOffOutline"/>
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                </Grid>

                <!-- Error Message -->
                <materialDesign:Card Margin="0,10"
                                   Background="#FFEBEE"
                                   Padding="8"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" 
                                               Foreground="#B71C1C"
                                               VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                 Margin="8,0,0,0"
                                 Foreground="#B71C1C"
                                 TextWrapping="Wrap"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Login Button -->
                <Button Command="{Binding LoginCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="45"
                        Margin="0,20,0,0"
                        materialDesign:ButtonAssist.CornerRadius="22.5"
                        Background="{DynamicResource PrimaryHueDarkBrush}"
                        BorderBrush="{DynamicResource PrimaryHueDarkBrush}"
                        Foreground="{DynamicResource MaterialDesignPaper}"
                        IsEnabled="{Binding CanLogin}">
                    <Grid>
                        <TextBlock Text="LOGIN"
                                 FontSize="14"
                                 FontWeight="Bold"
                                 Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                   Value="0"
                                   IsIndeterminate="True"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Width="20" Height="20"/>
                    </Grid>
                </Button>
            </StackPanel>

            <!-- Footer -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding ExitCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="15,0,0,15"
                        ToolTip="Exit Application">
                    <materialDesign:PackIcon Kind="ExitToApp" Width="24" Height="24"/>
                </Button>

                <TextBlock Grid.Column="1"
                         Text="Aethon © 2024 DTC Billing System"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="0,0,0,15"
                         Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                <Button Grid.Column="2"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,15,15"
                        Click="MinimizeButton_Click"
                        ToolTip="Minimize">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="24" Height="24"/>
                </Button>
            </Grid>
        </Grid>
    </materialDesign:Card>
</Window> 