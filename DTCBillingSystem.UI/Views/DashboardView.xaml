<UserControl x:Class="DTCBillingSystem.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:DTCBillingSystem.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f3f4f6" Offset="0"/>
            <GradientStop Color="#ffffff" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:StringNotEmptyToBooleanConverter x:Key="StringNotEmptyToBooleanConverter"/>
            
            <Style x:Key="DashboardCard" TargetType="materialDesign:Card">
                <Setter Property="Margin" Value="12"/>
                <Setter Property="Padding" Value="24"/>
                <Setter Property="UniformCornerRadius" Value="16"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1"/>
                <Setter Property="materialDesign:TransitionAssist.DisableTransitions" Value="False"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="20" 
                                        ShadowDepth="0" 
                                        Opacity="0.1" 
                                        Color="#000000"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="30" 
                                                ShadowDepth="0" 
                                                Opacity="0.15" 
                                                Color="#000000"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <Style x:Key="StatisticValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="36"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="Margin" Value="0,16,0,8"/>
                <Setter Property="TextAlignment" Value="Left"/>
            </Style>
            
            <Style x:Key="StatisticLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
                <Setter Property="TextAlignment" Value="Left"/>
                <Setter Property="Opacity" Value="0.8"/>
            </Style>

            <Style x:Key="IconStyle" TargetType="materialDesign:PackIcon">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Foreground" Value="{DynamicResource SecondaryAccentBrush}"/>
                <Setter Property="Opacity" Value="0.9"/>
            </Style>

            <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">
                <Setter Property="Margin" Value="0,0,0,24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
            </Style>

            <Style x:Key="ListItemStyle" TargetType="ListViewItem">
                <Setter Property="Padding" Value="16,12"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Margin" Value="0,4"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <SolidColorBrush Color="{DynamicResource Primary100}" Opacity="0.1"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ListViewStyle" TargetType="ListView">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading Overlay with Fade Animation -->
        <Grid Grid.RowSpan="2" 
              Background="#80FFFFFF" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" 
                            Value="0" 
                            IsIndeterminate="True" 
                            Width="56" 
                            Height="56"
                            Foreground="{DynamicResource SecondaryAccentBrush}"/>
                <TextBlock Text="Loading..." 
                         Margin="0,16,0,0"
                         Style="{StaticResource MaterialDesignBody1TextBlock}"
                         Foreground="{DynamicResource MaterialDesignBody}"/>
            </StackPanel>
        </Grid>

        <!-- Error Message -->
        <materialDesign:Snackbar Grid.Row="0"
                                IsActive="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToBooleanConverter}}"
                                Message="{Binding ErrorMessage}"
                                Background="#ef4444"
                                ActionButtonStyle="{StaticResource MaterialDesignFlatButton}"/>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Margin="32" 
                     VerticalScrollBarVisibility="Auto"
                     Template="{StaticResource MaterialDesignScrollViewerTemplate}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Welcome Message -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <TextBlock Text="Welcome back!" 
                             Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                             FontWeight="Bold"
                             Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Here's what's happening with your billing system today."
                             Style="{StaticResource MaterialDesignBody1TextBlock}"
                             Margin="0,8,0,0"
                             Opacity="0.7"/>
                </StackPanel>

                <!-- Statistics Cards -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Revenue -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="CurrencyUsd" 
                                                   Style="{StaticResource IconStyle}"/>
                            <TextBlock Text="{Binding TotalRevenue, StringFormat=₱{0:N2}}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Total Revenue" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Total Customers -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AccountMultiple" 
                                                   Style="{StaticResource IconStyle}"/>
                            <TextBlock Text="{Binding TotalCustomers}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Total Customers" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Pending Bills -->
                    <materialDesign:Card Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="FileDocument" 
                                                   Style="{StaticResource IconStyle}"/>
                            <TextBlock Text="{Binding PendingBills}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Pending Bills" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Overdue Payments -->
                    <materialDesign:Card Grid.Column="3" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AlertCircle" 
                                                   Style="{StaticResource IconStyle}"/>
                            <TextBlock Text="{Binding OverduePayments}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Overdue Payments" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Recent Activity Section -->
                <Grid Grid.Row="2" Margin="0,32,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent Bills -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <DockPanel>
                            <TextBlock Text="Recent Bills" 
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource SectionTitle}"/>
                            <ListView ItemsSource="{Binding RecentBills}"
                                    Style="{StaticResource ListViewStyle}"
                                    ItemContainerStyle="{StaticResource ListItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Receipt" 
                                                                   Width="24" 
                                                                   Height="24"
                                                                   Margin="0,0,16,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Customer.Name}" 
                                                         FontWeight="Medium"
                                                         FontSize="14"/>
                                                <TextBlock Text="{Binding BillNumber}"
                                                         Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                         FontSize="12"
                                                         Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" 
                                                     Text="{Binding TotalAmount, StringFormat=₱{0:N2}}"
                                                     FontWeight="Medium"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </materialDesign:Card>

                    <!-- Recent Payments -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource DashboardCard}">
                        <DockPanel>
                            <TextBlock Text="Recent Payments" 
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource SectionTitle}"/>
                            <ListView ItemsSource="{Binding RecentPayments}"
                                    Style="{StaticResource ListViewStyle}"
                                    ItemContainerStyle="{StaticResource ListItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="CashCheck" 
                                                                   Width="24" 
                                                                   Height="24"
                                                                   Margin="0,0,16,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource SecondaryAccentBrush}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Bill.Customer.Name}" 
                                                         FontWeight="Medium"
                                                         FontSize="14"/>
                                                <TextBlock Text="{Binding ReferenceNumber}"
                                                         Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                         FontSize="12"
                                                         Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" 
                                                     Text="{Binding Amount, StringFormat=₱{0:N2}}"
                                                     FontWeight="Medium"
                                                     Foreground="{DynamicResource SecondaryAccentBrush}"
                                                     VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl> 