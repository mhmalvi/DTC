<UserControl x:Class="DTCBillingSystem.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:DTCBillingSystem.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:StringNotEmptyToBooleanConverter x:Key="StringNotEmptyToBooleanConverter"/>
            
            <Style x:Key="DashboardCard" TargetType="materialDesign:Card">
                <Setter Property="Margin" Value="8"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="UniformCornerRadius" Value="8"/>
                <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}"/>
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
            </Style>
            
            <Style x:Key="StatisticValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="Margin" Value="0,8,0,4"/>
            </Style>
            
            <Style x:Key="StatisticLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" 
              Background="{DynamicResource MaterialDesignPaper}" 
              Opacity="0.9" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" 
                        Value="0" 
                        IsIndeterminate="True" 
                        Width="50" 
                        Height="50"/>
        </Grid>

        <!-- Error Message -->
        <materialDesign:Snackbar Grid.Row="0"
                                IsActive="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToBooleanConverter}}"
                                Message="{Binding ErrorMessage}"/>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Margin="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Statistics Cards -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Revenue -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="CurrencyUsd" 
                                                   Width="24" 
                                                   Height="24"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                            <TextBlock Text="{Binding TotalRevenue, StringFormat=₱{0:N2}}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Total Revenue" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Total Customers -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AccountMultiple" 
                                                   Width="24" 
                                                   Height="24"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                            <TextBlock Text="{Binding TotalCustomers}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Total Customers" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Pending Bills -->
                    <materialDesign:Card Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="FileDocument" 
                                                   Width="24" 
                                                   Height="24"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                            <TextBlock Text="{Binding PendingBills}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Pending Bills" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Overdue Payments -->
                    <materialDesign:Card Grid.Column="3" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AlertCircle" 
                                                   Width="24" 
                                                   Height="24"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                            <TextBlock Text="{Binding OverduePayments}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Overdue Payments" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Recent Activity Section -->
                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent Bills -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <DockPanel>
                            <TextBlock Text="Recent Bills" 
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                     Margin="0,0,0,16"/>
                            <ListView ItemsSource="{Binding RecentBills}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Receipt" 
                                                                   Width="24" 
                                                                   Height="24"
                                                                   Margin="0,0,16,0"
                                                                   VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Customer.Name}" 
                                                         FontWeight="Medium"/>
                                                <TextBlock Text="{Binding BillNumber}"
                                                         Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" 
                                                     Text="{Binding TotalAmount, StringFormat=₱{0:N2}}"
                                                     FontWeight="Medium"
                                                     VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </materialDesign:Card>

                    <!-- Recent Payments -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource DashboardCard}">
                        <DockPanel>
                            <TextBlock Text="Recent Payments" 
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                     Margin="0,0,0,16"/>
                            <ListView ItemsSource="{Binding RecentPayments}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="CashCheck" 
                                                                   Width="24" 
                                                                   Height="24"
                                                                   Margin="0,0,16,0"
                                                                   VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Bill.Customer.Name}" 
                                                         FontWeight="Medium"/>
                                                <TextBlock Text="{Binding ReferenceNumber}"
                                                         Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" 
                                                     Text="{Binding Amount, StringFormat=₱{0:N2}}"
                                                     FontWeight="Medium"
                                                     VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl> 