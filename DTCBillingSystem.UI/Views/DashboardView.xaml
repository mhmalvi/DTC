<UserControl x:Class="DTCBillingSystem.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:DTCBillingSystem.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1a1f2e" Offset="0"/>
            <GradientStop Color="#242937" Offset="0.5"/>
            <GradientStop Color="#1e2433" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:StringNotEmptyToBooleanConverter x:Key="StringNotEmptyToBooleanConverter"/>
            
            <!-- Glassmorphism Card Style -->
            <Style x:Key="GlassmorphismCard" TargetType="materialDesign:Card">
                <Setter Property="Margin" Value="12"/>
                <Setter Property="Padding" Value="28"/>
                <Setter Property="UniformCornerRadius" Value="24"/>
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
                <Setter Property="materialDesign:TransitionAssist.DisableTransitions" Value="False"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.15">
                            <GradientStop Color="#ffffff" Offset="0"/>
                            <GradientStop Color="#242937" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="30" 
                                        ShadowDepth="0" 
                                        Opacity="0.3" 
                                        Color="#00ffff"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.2">
                            <GradientStop Color="#ffffff" Offset="0"/>
                            <GradientStop Color="#00ffff" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="40" 
                                                ShadowDepth="0" 
                                                Opacity="0.4" 
                                                Color="#00ffff"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.2">
                                    <GradientStop Color="#ffffff" Offset="0"/>
                                    <GradientStop Color="#242937" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Enhanced Statistic Value Style -->
            <Style x:Key="StatisticValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="42"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00ffff" Offset="0"/>
                            <GradientStop Color="#00cccc" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Margin" Value="0,20,0,10"/>
                <Setter Property="TextAlignment" Value="Left"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="20" 
                                        ShadowDepth="0" 
                                        Opacity="0.4" 
                                        Color="#00ffff"/>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Enhanced Statistic Label Style -->
            <Style x:Key="StatisticLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="#a0aec0"/>
                <Setter Property="TextAlignment" Value="Left"/>
                <Setter Property="Opacity" Value="0.9"/>
            </Style>

            <!-- Enhanced Icon Style -->
            <Style x:Key="IconStyle" TargetType="materialDesign:PackIcon">
                <Setter Property="Width" Value="38"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="Foreground">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00ffff" Offset="0"/>
                            <GradientStop Color="#00cccc" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Opacity" Value="0.95"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="15" 
                                        ShadowDepth="0" 
                                        Opacity="0.4" 
                                        Color="#00ffff"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Enhanced Section Title Style -->
            <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">
                <Setter Property="Margin" Value="0,0,0,28"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="Foreground">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00ffff" Offset="0"/>
                            <GradientStop Color="#00cccc" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Glassmorphism List Item Style -->
            <Style x:Key="ListItemStyle" TargetType="ListViewItem">
                <Setter Property="Padding" Value="20,16"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Margin" Value="0,8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.15">
                                                <GradientStop Color="#ffffff" Offset="0"/>
                                                <GradientStop Color="#00ffff" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Border" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="20" 
                                                            ShadowDepth="0" 
                                                            Opacity="0.2" 
                                                            Color="#00ffff"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Enhanced List View Style -->
            <Style x:Key="ListViewStyle" TargetType="ListView">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" 
                Background="#1e2433" 
                BorderBrush="#2d3748" 
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="24,32,24,40">
                    <TextBlock Text="DTC Billing" 
                             FontSize="24" 
                             FontWeight="Bold"
                             Foreground="#00ffff">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="15" 
                                            ShadowDepth="0" 
                                            Opacity="0.4" 
                                            Color="#00ffff"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Management System" 
                             FontSize="14"
                             Margin="0,4,0,0"
                             Foreground="#a0aec0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#00ffff"
                            Background="#242937">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Command="{Binding NavigateToCustomersCommand}"
                            Foreground="#00ffff">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountMultiple" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Customers" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocument" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Bills" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CashRegister" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Payments" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartLine" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Reports" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Settings" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Column="1" 
                     Margin="40" 
                     VerticalScrollBarVisibility="Auto"
                     Template="{StaticResource MaterialDesignScrollViewerTemplate}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Welcome Message -->
                <StackPanel Grid.Row="0" Margin="0,0,0,40">
                    <TextBlock Text="Welcome back!" 
                             Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                             FontWeight="Bold"
                             FontSize="42"
                             Foreground="#00ffff">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="20" 
                                            ShadowDepth="0" 
                                            Opacity="0.4" 
                                            Color="#00ffff"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Here's what's happening with your billing system today."
                             Style="{StaticResource MaterialDesignBody1TextBlock}"
                             FontSize="16"
                             Margin="0,12,0,0"
                             Foreground="#a0aec0"
                             Opacity="0.9"/>
                </StackPanel>

                <!-- Statistics Cards -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Revenue -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource GlassmorphismCard}">
                        <materialDesign:Card.RenderTransform>
                            <TranslateTransform/>
                        </materialDesign:Card.RenderTransform>
                        <StackPanel>
                            <materialDesign:PackIcon Kind="CurrencyUsd" 
                                                   Style="{StaticResource IconStyle}"/>
                            <TextBlock Text="{Binding TotalRevenue, StringFormat=₱{0:N2}}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Total Revenue" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Total Customers -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource GlassmorphismCard}">
                        <materialDesign:Card.RenderTransform>
                            <TranslateTransform/>
                        </materialDesign:Card.RenderTransform>
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AccountMultiple" 
                                                   Style="{StaticResource IconStyle}"/>
                            <TextBlock Text="{Binding TotalCustomers}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Total Customers" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Pending Bills -->
                    <materialDesign:Card Grid.Column="2" Style="{StaticResource GlassmorphismCard}">
                        <materialDesign:Card.RenderTransform>
                            <TranslateTransform/>
                        </materialDesign:Card.RenderTransform>
                        <StackPanel>
                            <materialDesign:PackIcon Kind="FileDocument" 
                                                   Style="{StaticResource IconStyle}"/>
                            <TextBlock Text="{Binding PendingBills}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Pending Bills" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Overdue Payments -->
                    <materialDesign:Card Grid.Column="3" Style="{StaticResource GlassmorphismCard}">
                        <materialDesign:Card.RenderTransform>
                            <TranslateTransform/>
                        </materialDesign:Card.RenderTransform>
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AlertCircle" 
                                                   Style="{StaticResource IconStyle}"/>
                            <TextBlock Text="{Binding OverduePayments}" 
                                     Style="{StaticResource StatisticValue}"/>
                            <TextBlock Text="Overdue Payments" 
                                     Style="{StaticResource StatisticLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Additional Cards Row -->
                <Grid Grid.Row="2" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Monthly Revenue Chart -->
                    <materialDesign:Card Grid.Column="0" 
                                       Style="{StaticResource GlassmorphismCard}"
                                       Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock Text="Monthly Revenue" 
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource SectionTitle}"/>
                            <Grid Height="200">
                                <!-- Add chart here -->
                                <TextBlock Text="Chart Placeholder" 
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         Foreground="#a0aec0"/>
                            </Grid>
                        </DockPanel>
                    </materialDesign:Card>

                    <!-- Payment Status -->
                    <materialDesign:Card Grid.Column="1" 
                                       Style="{StaticResource GlassmorphismCard}"
                                       Margin="12,0,0,0">
                        <DockPanel>
                            <TextBlock Text="Payment Status" 
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource SectionTitle}"/>
                            <Grid Height="200">
                                <!-- Add chart here -->
                                <TextBlock Text="Chart Placeholder" 
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         Foreground="#a0aec0"/>
                            </Grid>
                        </DockPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Recent Activity Section -->
                <Grid Grid.Row="3" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent Bills -->
                    <materialDesign:Card Grid.Column="0" 
                                       Style="{StaticResource GlassmorphismCard}"
                                       Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock Text="Recent Bills" 
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource SectionTitle}"/>
                            <ListView ItemsSource="{Binding RecentBills}"
                                    Style="{StaticResource ListViewStyle}"
                                    ItemContainerStyle="{StaticResource ListItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Receipt" 
                                                                   Width="24" 
                                                                   Height="24"
                                                                   Margin="0,0,16,0"
                                                                   Foreground="#00ffff"
                                                                   VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" 
                                                      Margin="0,0,16,0">
                                                <TextBlock Text="{Binding CustomerName}" 
                                                         FontWeight="SemiBold"
                                                         FontSize="14"
                                                         Foreground="#e2e8f0"/>
                                                <TextBlock Text="{Binding Date, StringFormat={}{0:MMM dd, yyyy}}"
                                                         Opacity="0.7"
                                                         FontSize="12"
                                                         Foreground="#a0aec0"
                                                         Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" 
                                                     Text="{Binding Amount, StringFormat=₱{0:N2}}"
                                                     FontWeight="SemiBold"
                                                     VerticalAlignment="Center"
                                                     Foreground="#00ffff"
                                                     FontSize="14"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </materialDesign:Card>

                    <!-- Recent Activities -->
                    <materialDesign:Card Grid.Column="1" 
                                       Style="{StaticResource GlassmorphismCard}"
                                       Margin="12,0,0,0">
                        <DockPanel>
                            <TextBlock Text="Recent Activities" 
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource SectionTitle}"/>
                            <ListView Style="{StaticResource ListViewStyle}"
                                    ItemContainerStyle="{StaticResource ListItemStyle}">
                                <ListViewItem>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="Bell" 
                                                               Width="24" 
                                                               Height="24"
                                                               Margin="0,0,16,0"
                                                               Foreground="#00ffff"
                                                               VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="New Payment Received" 
                                                     FontWeight="SemiBold"
                                                     FontSize="14"
                                                     Foreground="#e2e8f0"/>
                                            <TextBlock Text="2 minutes ago"
                                                     Opacity="0.7"
                                                     FontSize="12"
                                                     Foreground="#a0aec0"
                                                     Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </ListViewItem>
                                <ListViewItem>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="AlertCircle" 
                                                               Width="24" 
                                                               Height="24"
                                                               Margin="0,0,16,0"
                                                               Foreground="#00ffff"
                                                               VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Bill Due Reminder" 
                                                     FontWeight="SemiBold"
                                                     FontSize="14"
                                                     Foreground="#e2e8f0"/>
                                            <TextBlock Text="15 minutes ago"
                                                     Opacity="0.7"
                                                     FontSize="12"
                                                     Foreground="#a0aec0"
                                                     Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </ListViewItem>
                            </ListView>
                        </DockPanel>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl> 