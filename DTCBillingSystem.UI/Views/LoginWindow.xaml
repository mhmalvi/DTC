<Window x:Class="DTCBillingSystem.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="DTC Billing System - Login" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <Color x:Key="CustomCyanColor">#00FFF0</Color>
        <SolidColorBrush x:Key="CustomCyanBrush" Color="{StaticResource CustomCyanColor}"/>
    </Window.Resources>

    <Border Background="#FF1C1F26" 
            CornerRadius="10" 
            BorderThickness="1" 
            BorderBrush="#FF2D3039">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Window Control Buttons -->
            <Grid Grid.Row="0" Height="32">
                <StackPanel HorizontalAlignment="Right" 
                          Orientation="Horizontal" 
                          Margin="0,4,10,0">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Height="24" Width="24" 
                            Padding="0"
                            Click="MinimizeButton_Click">
                        <materialDesign:PackIcon Kind="WindowMinimize" 
                                               Foreground="#CCFFFFFF"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Height="24" Width="24"
                            Padding="0"
                            Margin="4,0,0,0"
                            Click="CloseButton_Click">
                        <materialDesign:PackIcon Kind="Close" 
                                               Foreground="#CCFFFFFF"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Border Grid.Row="1" 
                    Margin="32"
                    Background="#FF262A35"
                    CornerRadius="15"
                    BorderThickness="1"
                    BorderBrush="{StaticResource CustomCyanBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" 
                                    ShadowDepth="0" 
                                    Color="#4000FFF0"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side - Welcome Panel -->
                    <Grid Grid.Column="0" Margin="32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Welcome Text -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Welcome to"
                                     Foreground="#E6FFFFFF"
                                     FontSize="24"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="DTC Billing System"
                                     Foreground="{StaticResource CustomCyanBrush}"
                                     FontSize="36"
                                     FontWeight="Bold"/>
                            <TextBlock Text="Your Complete Billing Solution"
                                     Foreground="#E6FFFFFF"
                                     FontSize="20"
                                     Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Version Info -->
                        <StackPanel Grid.Row="2" 
                                  VerticalAlignment="Bottom">
                            <TextBlock Text="Version 1.0.0"
                                     Foreground="#CCFFFFFF"
                                     FontSize="12"/>
                            <TextBlock Text="© 2024 DTC Billing System. All rights reserved."
                                     Foreground="#CCFFFFFF"
                                     FontSize="12"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Right Side - Login Form -->
                    <StackPanel Grid.Column="1" 
                              Margin="32"
                              VerticalAlignment="Center">
                        <TextBlock Text="Login"
                                 Foreground="{StaticResource CustomCyanBrush}"
                                 FontSize="32"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"/>
                                 
                        <TextBlock Text="Please sign in to continue"
                                 Foreground="#E6FFFFFF"
                                 FontSize="16"
                                 HorizontalAlignment="Center"
                                 Margin="0,8,0,32"/>

                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                materialDesign:HintAssist.Hint="Username"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource CustomCyanBrush}"
                                materialDesign:HintAssist.Foreground="{StaticResource CustomCyanBrush}"
                                Style="{StaticResource MaterialDesignFilledTextBox}"
                                Background="#FF1C1F26"
                                Foreground="#E6FFFFFF"
                                Margin="0,16,0,0"
                                FontSize="14"/>

                        <PasswordBox x:Name="PasswordBox"
                                   materialDesign:HintAssist.Hint="Password"
                                   materialDesign:TextFieldAssist.HasClearButton="True"
                                   materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource CustomCyanBrush}"
                                   materialDesign:HintAssist.Foreground="{StaticResource CustomCyanBrush}"
                                   Style="{StaticResource MaterialDesignFilledPasswordBox}"
                                   Background="#FF1C1F26"
                                   Foreground="#E6FFFFFF"
                                   Margin="0,16,0,0"
                                   FontSize="14"/>

                        <Button Content="LOGIN"
                                Command="{Binding LoginCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Background="{StaticResource CustomCyanBrush}"
                                Foreground="#FF1C1F26"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="45"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0,32,0,0">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="10" 
                                                ShadowDepth="0" 
                                                Color="#4000FFF0"/>
                            </Button.Effect>
                        </Button>

                        <TextBlock Text="{Binding ErrorMessage}"
                                 Foreground="#FFFF4444"
                                 TextWrapping="Wrap"
                                 HorizontalAlignment="Center"
                                 Margin="0,16,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window> 