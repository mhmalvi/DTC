<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="DTCBillingSystem.UI.Views.CustomersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DTCBillingSystem.UI.Views"
        xmlns:vm="clr-namespace:DTCBillingSystem.UI.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:DTCBillingSystem.UI.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:enums="clr-namespace:DTCBillingSystem.Core.Models.Enums;assembly=DTCBillingSystem.Core"
        mc:Ignorable="d"
        d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1a1f2e" Offset="0"/>
            <GradientStop Color="#242937" Offset="0.5"/>
            <GradientStop Color="#1e2433" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
            <converters:BoolToActionTextConverter x:Key="BoolToActionTextConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <!-- Customer Types -->
            <ObjectDataProvider x:Key="CustomerTypes" 
                              MethodName="GetValues"
                              ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="enums:CustomerType"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>

            <!-- Sort Options -->
            <x:Array x:Key="SortOptions" Type="sys:String" 
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
                <sys:String>Name</sys:String>
                <sys:String>Account Number</sys:String>
                <sys:String>Type</sys:String>
                <sys:String>Zone</sys:String>
            </x:Array>

            <!-- Glassmorphism Card Style -->
            <Style x:Key="GlassmorphismCard" TargetType="materialDesign:Card">
                <Setter Property="Margin" Value="12"/>
                <Setter Property="Padding" Value="24"/>
                <Setter Property="UniformCornerRadius" Value="15"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.15">
                            <GradientStop Color="#ffffff" Offset="0"/>
                            <GradientStop Color="#242937" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="30" 
                                        ShadowDepth="0" 
                                        Opacity="0.3" 
                                        Color="#00ffff"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.2">
                            <GradientStop Color="#ffffff" Offset="0"/>
                            <GradientStop Color="#00ffff" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Modern Button Style -->
            <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground" Value="#00ffff"/>
                <Setter Property="Background" Value="#242937"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00ffff" Offset="0"/>
                            <GradientStop Color="#242937" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="15" 
                                        ShadowDepth="0" 
                                        Opacity="0.3" 
                                        Color="#00ffff"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- DataGrid Styles -->
            <Style x:Key="ModernDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground">
                    <Setter.Value>
                        <SolidColorBrush Color="#242937" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" 
                Background="#1e2433" 
                BorderBrush="#2d3748" 
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="24,32,24,40">
                    <TextBlock Text="DTC Billing" 
                             FontSize="24" 
                             FontWeight="Bold"
                             Foreground="#00ffff">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="15" 
                                            ShadowDepth="0" 
                                            Opacity="0.4" 
                                            Color="#00ffff"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Management System" 
                             FontSize="14"
                             Margin="0,4,0,0"
                             Foreground="#a0aec0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Command="{Binding NavigateToDashboardCommand}"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#00ffff"
                            Background="#242937">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountMultiple" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Customers" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocument" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Bills" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CashRegister" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Payments" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartLine" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Reports" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Height="48" 
                            Margin="12,4"
                            Command="{Binding NavigateToSettingsCommand}"
                            Foreground="#a0aec0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,12,0"/>
                            <TextBlock Text="Settings" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Main Content Card -->
            <materialDesign:Card Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource GlassmorphismCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Title -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Customers"
                                     Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                     FontWeight="Bold"
                                     Foreground="#00ffff">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="20"
                                                    ShadowDepth="0"
                                                    Opacity="0.4"
                                                    Color="#00ffff"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="Manage your customer base."
                                     Style="{StaticResource MaterialDesignBody1TextBlock}"
                                     Margin="0,8,0,0"
                                     Foreground="#a0aec0"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="2" 
                                  Orientation="Horizontal" 
                                  HorizontalAlignment="Right">
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding RefreshCommand}"
                                    Margin="8,0"
                                    ToolTip="Refresh">
                                <materialDesign:PackIcon Kind="Refresh" 
                                                       Width="24" 
                                                       Height="24"/>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding AddCustomerCommand}"
                                    Margin="8,0"
                                    ToolTip="Add Customer">
                                <materialDesign:PackIcon Kind="Plus" 
                                                       Width="24" 
                                                       Height="24"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Search and Filter Bar -->
                    <Grid Grid.Row="1" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Box -->
                        <TextBox Grid.Column="0"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                materialDesign:HintAssist.Hint="Search customers..."
                                Margin="0,0,16,0"/>

                        <!-- Type Filter -->
                        <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding Source={StaticResource CustomerTypes}}"
                                 SelectedItem="{Binding SelectedCustomerType}"
                                 Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                 materialDesign:HintAssist.Hint="Type"
                                 Width="120"
                                 Margin="0,0,16,0"/>

                        <!-- Sort By -->
                        <ComboBox Grid.Column="2"
                                 ItemsSource="{Binding Source={StaticResource SortOptions}}"
                                 SelectedItem="{Binding SelectedSortOption}"
                                 Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                 materialDesign:HintAssist.Hint="Sort by"
                                 Width="120"
                                 Margin="0,0,16,0"/>

                        <!-- Active Only Toggle -->
                        <ToggleButton Grid.Column="3"
                                    IsChecked="{Binding ShowActiveOnly}"
                                    Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                    ToolTip="Show Active Only"/>
                    </Grid>

                    <!-- Customers DataGrid -->
                    <DataGrid Grid.Row="2"
                             ItemsSource="{Binding Customers}"
                             SelectedItem="{Binding SelectedCustomer}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             IsReadOnly="True"
                             Style="{StaticResource MaterialDesignDataGrid}"
                             materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                             materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Account #" 
                                              Binding="{Binding AccountNumber}"
                                              Width="120"/>
                            <DataGridTextColumn Header="Name" 
                                              Binding="{Binding Name}"
                                              Width="*"/>
                            <DataGridTextColumn Header="Type" 
                                              Binding="{Binding Type}"
                                              Width="100"/>
                            <DataGridTextColumn Header="Zone" 
                                              Binding="{Binding Zone}"
                                              Width="100"/>
                            <DataGridTextColumn Header="Contact" 
                                              Binding="{Binding ContactNumber}"
                                              Width="120"/>
                            <DataGridTextColumn Header="Balance" 
                                              Binding="{Binding Balance, StringFormat=₱{0:N2}}"
                                              Width="120"/>
                            <DataGridTemplateColumn Header="Status" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToStatusConverter}}"
                                                 Foreground="{Binding IsActive, Converter={StaticResource BoolToStatusConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Actions" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.EditCustomerCommand, 
                                                             RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Edit">
                                                <materialDesign:PackIcon Kind="Pencil" />
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.ToggleCustomerStatusCommand, 
                                                             RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{Binding IsActive, 
                                                             Converter={StaticResource BoolToActionTextConverter}}">
                                                <materialDesign:PackIcon Kind="{Binding IsActive, 
                                                                        Converter={StaticResource BoolToActionIconConverter}}" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination -->
                    <Grid Grid.Row="3" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Items per page -->
                        <ComboBox Grid.Column="0"
                                 ItemsSource="{Binding PageSizeOptions}"
                                 SelectedItem="{Binding SelectedPageSize}"
                                 Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                 materialDesign:HintAssist.Hint="Items per page"
                                 Width="100"/>

                        <!-- Page navigation -->
                        <StackPanel Grid.Column="2" 
                                  Orientation="Horizontal"
                                  HorizontalAlignment="Right">
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding PreviousPageCommand}">
                                <materialDesign:PackIcon Kind="ChevronLeft"/>
                            </Button>
                            <TextBlock Text="{Binding CurrentPage}"
                                     VerticalAlignment="Center"
                                     Margin="8,0"/>
                            <TextBlock Text="of"
                                     VerticalAlignment="Center"
                                     Margin="8,0"/>
                            <TextBlock Text="{Binding TotalPages}"
                                     VerticalAlignment="Center"
                                     Margin="8,0"/>
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding NextPageCommand}">
                                <materialDesign:PackIcon Kind="ChevronRight"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl> 