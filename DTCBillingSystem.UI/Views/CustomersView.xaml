<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="DTCBillingSystem.UI.Views.CustomersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DTCBillingSystem.UI.Views"
        xmlns:vm="clr-namespace:DTCBillingSystem.UI.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:DTCBillingSystem.UI.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:enums="clr-namespace:DTCBillingSystem.Core.Models.Enums;assembly=DTCBillingSystem.Core"
        mc:Ignorable="d"
        d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1a1f2e" Offset="0"/>
            <GradientStop Color="#242937" Offset="0.5"/>
            <GradientStop Color="#1e2433" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
            <converters:BoolToActionTextConverter x:Key="BoolToActionTextConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <!-- Customer Types -->
            <ObjectDataProvider x:Key="CustomerTypes" 
                              MethodName="GetValues"
                              ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="enums:CustomerType"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>

            <!-- Sort Options -->
            <x:Array x:Key="SortOptions" Type="sys:String" 
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
                <sys:String>Name</sys:String>
                <sys:String>Account Number</sys:String>
                <sys:String>Type</sys:String>
                <sys:String>Zone</sys:String>
            </x:Array>

            <!-- Glassmorphism Card Style -->
            <Style x:Key="GlassmorphismCard" TargetType="materialDesign:Card">
                <Setter Property="Margin" Value="12"/>
                <Setter Property="Padding" Value="24"/>
                <Setter Property="UniformCornerRadius" Value="15"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.15">
                            <GradientStop Color="#ffffff" Offset="0"/>
                            <GradientStop Color="#242937" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="30" 
                                        ShadowDepth="0" 
                                        Opacity="0.3" 
                                        Color="#00ffff"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.2">
                            <GradientStop Color="#ffffff" Offset="0"/>
                            <GradientStop Color="#00ffff" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Modern Button Style -->
            <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground" Value="#00ffff"/>
                <Setter Property="Background" Value="#242937"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00ffff" Offset="0"/>
                            <GradientStop Color="#242937" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="15" 
                                        ShadowDepth="0" 
                                        Opacity="0.3" 
                                        Color="#00ffff"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- DataGrid Styles -->
            <Style x:Key="ModernDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground">
                    <Setter.Value>
                        <SolidColorBrush Color="#242937" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main Content Card -->
        <materialDesign:Card Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource GlassmorphismCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="Customers" 
                                 FontSize="32" 
                                 FontWeight="Bold" 
                                 Foreground="#00ffff">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="20" 
                                                ShadowDepth="0" 
                                                Opacity="0.4" 
                                                Color="#00ffff"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Manage your customer base" 
                                 Foreground="#a0aec0" 
                                 Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" 
                              Orientation="Horizontal" 
                              HorizontalAlignment="Right">
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding AddCustomerCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountPlus" 
                                                       Margin="0,0,8,0"/>
                                <TextBlock Text="Add Customer"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding RefreshCommand}"
                                Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" 
                                                       Margin="0,0,8,0"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Search and Filters -->
                <Grid Grid.Row="1" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Search customers..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Foreground="#e2e8f0"
                             Margin="0,0,16,0"/>

                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding Source={StaticResource CustomerTypes}}"
                              SelectedItem="{Binding SelectedCustomerType}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Width="150" 
                              Margin="0,0,16,0"/>

                    <ComboBox Grid.Column="2" 
                              ItemsSource="{Binding Source={StaticResource SortOptions}}"
                              SelectedItem="{Binding SortBy}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Width="150" 
                              Margin="0,0,16,0"/>

                    <CheckBox Grid.Column="3" 
                              Content="Active Only" 
                              IsChecked="{Binding IsActive}"
                              Foreground="#e2e8f0"/>
                </Grid>

                <!-- Customer List -->
                <DataGrid Grid.Row="2" 
                          ItemsSource="{Binding Customers}"
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          SelectionMode="Single" 
                          SelectionUnit="FullRow"
                          CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Account #" 
                                          Binding="{Binding AccountNumber}"
                                          ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                        <DataGridTextColumn Header="Name" 
                                          Binding="{Binding Name}"
                                          ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                        <DataGridTextColumn Header="Type" 
                                          Binding="{Binding Type}"
                                          ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                        <DataGridTextColumn Header="Zone" 
                                          Binding="{Binding ZoneCode}"
                                          ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                        <DataGridTextColumn Header="Contact" 
                                          Binding="{Binding ContactNumber}"
                                          ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                        <DataGridTextColumn Header="Balance" 
                                          Binding="{Binding CurrentBalance, StringFormat=C2}"
                                          ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                        <DataGridTextColumn Header="Status" 
                                          Binding="{Binding IsActive, Converter={StaticResource BoolToStatusConverter}}"
                                          ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                        <DataGridTemplateColumn Header="Actions">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.EditCustomerCommand, 
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Edit">
                                            <materialDesign:PackIcon Kind="Edit"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.ViewBillsCommand, 
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="View Bills">
                                            <materialDesign:PackIcon Kind="FileDocument"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.ActivateDeactivateCommand, 
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{Binding IsActive, Converter={StaticResource BoolToActionTextConverter}}">
                                            <materialDesign:PackIcon Kind="{Binding IsActive, 
                                                                    Converter={StaticResource BooleanToStatusIconConverter}}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination -->
                <Grid Grid.Row="3" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" 
                              ItemsSource="{Binding PageSizes}" 
                              SelectedItem="{Binding ItemsPerPage}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Width="100" 
                              HorizontalAlignment="Left"/>

                    <StackPanel Grid.Column="1" 
                              Orientation="Horizontal" 
                              HorizontalAlignment="Center">
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding CanGoToPreviousPage}">
                            <materialDesign:PackIcon Kind="ChevronLeft"/>
                        </Button>
                        <TextBlock Text="{Binding CurrentPage}" 
                                 VerticalAlignment="Center"
                                 Foreground="#e2e8f0"
                                 Margin="16,0"/>
                        <TextBlock Text="of" 
                                 VerticalAlignment="Center"
                                 Foreground="#a0aec0"
                                 Margin="8,0"/>
                        <TextBlock Text="{Binding TotalPages}" 
                                 VerticalAlignment="Center"
                                 Foreground="#e2e8f0"
                                 Margin="16,0"/>
                        <Button Style="{StaticResource ModernButton}"
                                Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanGoToNextPage}">
                            <materialDesign:PackIcon Kind="ChevronRight"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" 
              Background="#80000000" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                        Value="0"
                        IsIndeterminate="True"
                        Width="50"
                        Height="50"/>
        </Grid>
    </Grid>
</UserControl> 