<Page x:Class="DTCBillingSystem.UI.Views.CustomerDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:DTCBillingSystem.UI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="500"
      Title="Customer">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="{Binding DialogTitle}"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,24"/>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Shop No -->
                <TextBox materialDesign:HintAssist.Hint="Shop No"
                         Text="{Binding Customer.ShopNo, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>
                <TextBlock Text="{Binding ShopNoError}"
                           Foreground="{StaticResource MaterialDesignError}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Margin="0,-12,0,16"
                           Visibility="{Binding ShopNoError, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Name -->
                <TextBox materialDesign:HintAssist.Hint="Name"
                         Text="{Binding Customer.Name, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>
                <TextBlock Text="{Binding NameError}"
                           Foreground="{StaticResource MaterialDesignError}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Margin="0,-12,0,16"
                           Visibility="{Binding NameError, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Floor -->
                <TextBox materialDesign:HintAssist.Hint="Floor"
                         Text="{Binding Customer.Floor, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>
                <TextBlock Text="{Binding FloorError}"
                           Foreground="{StaticResource MaterialDesignError}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Margin="0,-12,0,16"
                           Visibility="{Binding FloorError, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Customer Type -->
                <ComboBox materialDesign:HintAssist.Hint="Customer Type"
                          ItemsSource="{Binding CustomerTypes}"
                          SelectedItem="{Binding Customer.CustomerType}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,16"/>

                <!-- Contact Info -->
                <TextBox materialDesign:HintAssist.Hint="Phone Number"
                         Text="{Binding Customer.PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>

                <TextBox materialDesign:HintAssist.Hint="Email"
                         Text="{Binding Customer.Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>
                <TextBlock Text="{Binding EmailError}"
                           Foreground="{StaticResource MaterialDesignError}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Margin="0,-12,0,16"
                           Visibility="{Binding EmailError, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Additional Info -->
                <TextBox materialDesign:HintAssist.Hint="Notes"
                         Text="{Binding Customer.Notes}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="100"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,16"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0"/>
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignPrimaryButton}"/>
        </StackPanel>
    </Grid>
</Page> 